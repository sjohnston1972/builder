# Credentials for the wrangler CLI (deploys). Copy to `.env` and fill in.
# `.env` is gitignored — never commit real values.

# Cloudflare API token wrangler uses to authenticate `wrangler deploy`.
CLOUDFLARE_API_TOKEN=

# Your Cloudflare account id (also set in wrangler.toml as CF_ACCOUNT_ID).
CLOUDFLARE_ACCOUNT_ID=
